{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/secciones/[slug]",
      "regex": "^/admin/secciones/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/admin/secciones/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/section-cards/[id]",
      "regex": "^/api/admin/section\\-cards/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/section\\-cards/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/sections/[id]",
      "regex": "^/api/admin/sections/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/sections/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/spells/[id]/approve",
      "regex": "^/api/admin/spells/([^/]+?)/approve(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/spells/(?<nxtPid>[^/]+?)/approve(?:/)?$"
    },
    {
      "page": "/carta/[slug]",
      "regex": "^/carta/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/carta/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/secciones/[slug]",
      "regex": "^/secciones/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/secciones/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/secciones/[slug]/[cardSlug]",
      "regex": "^/secciones/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug",
        "nxtPcardSlug": "nxtPcardSlug"
      },
      "namedRegex": "^/secciones/(?<nxtPslug>[^/]+?)/(?<nxtPcardSlug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/acerca",
      "regex": "^/acerca(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/acerca(?:/)?$"
    },
    {
      "page": "/admin/secciones",
      "regex": "^/admin/secciones(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/secciones(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/hechizos",
      "regex": "^/hechizos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hechizos(?:/)?$"
    },
    {
      "page": "/secciones",
      "regex": "^/secciones(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/secciones(?:/)?$"
    },
    {
      "page": "/sugerencias",
      "regex": "^/sugerencias(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sugerencias(?:/)?$"
    },
    {
      "page": "/tiradas",
      "regex": "^/tiradas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tiradas(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}