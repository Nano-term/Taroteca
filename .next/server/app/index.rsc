ildren":["TAROTECA",["$","span",null,{"className":"text-gold","children":"."}]]}],["$","p",null,{"className":"mb-0 mt-1","children":"Una biblioteca abierta de tarot, en construcción junto a su comunidad."}]]}],["$","nav",null,{"className":"d-flex gap-4","children":[["$","$L6",null,{"href":"/","children":"Biblioteca"}],["$","$L6",null,{"href":"/tiradas","children":"Tiradas"}],["$","$L6",null,{"href":"/sugerencias","children":"Sugerencias"}],["$","$L6",null,{"href":"/acerca","children":"Acerca de"}]]}]]}]}]]}]}]}]]}],{"children":["__PAGE__",["$","$1","c",{"children":["$L7",[["$","script","script-0",{"src":"/_next/static/chunks/b75ed928077532d1.js","async":true,"nonce":"$undefined"}]],["$","$L8",null,{"children":["$L9",["$","$La",null,{"promise":"$@b"}]]}]]}],{},null,false]},null,false],["$","$1","h",{"children":[null,[["$","$Lc",null,{"children":"$Ld"}],["$","meta",null,{"name":"next-size-adjust","content":""}]],["$","$Le",null,{"children":["$","div",null,{"hidden":true,"children":["$","$f",null,{"fallback":null,"children":"$L10"}]}]}]]}],false]],"m":"$undefined","G":["$11",[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/d2d4c3c93409f723.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}],["$","link","1",{"rel":"stylesheet","href":"/_next/static/chunks/a87916f933b8012c.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}],["$","link","2",{"rel":"stylesheet","href":"/_next/static/chunks/8aca992eb13e8eba.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]]],"s":false,"S":true}
